    game: 'game',
    pendingGame: 'pending',
    completedGame: 'completed',
    divisionMember: 'member',
    selectedGame: 'selected',
    relatedGame: 'related',
    tooltip: 'tooltip',
    contextMenu: 'contextMenu',
    overlayHeader: 'overlay__header',
    controls: 'bracket__controls',
    navigation: 'bracket__navigation',
    title: 'bracket__title',
        };

class Styler {

    static overlay(elm) {
        elm.classList.add('overlay');
        elm.classList.add('bracket');
    }

    static selections(elm) {
        elm.classList.add('form__bar');
        elm.classList.add('mb');
    }

    static backButton(elm) {
        elm.src = '/assets/icons/right-arrow.svg';
        elm.classList.add('icon');
        elm.classList.add('smaller');
        elm.classList.add('flip');
        elm.classList.add('ml');
    }

    static forwardButton(elm) {
        elm.src = '/assets/icons/right-arrow.svg';
        elm.classList.add('icon');
        elm.classList.add('smaller');
        elm.classList.add('ml');
    }

    static openButton(elm) {
        elm.setAttribute('alt', 'Bracket Builder');
        elm.setAttribute('aria-label', 'Bracket Builder');
        elm.setAttribute('role', 'button');
        elm.setAttribute('tabindex', '0');
        elm.classList.add('icon');
        elm.classList.add('bracketOpen');
    }

    static closeButton(elm) {
        elm.src = '/assets/icons/cross.svg';
        elm.setAttribute('alt', 'Close Bracket Builder');
        elm.setAttribute('aria-label', 'Close Bracket Builder');
        elm.setAttribute('role', 'button');
        elm.setAttribute('tabindex', '0');
        elm.classList.add('icon');
        elm.classList.add('bracketClose');
    }

    static title(elm) {
        elm.classList.add(styles.title);
    }

    static controls(elm) {
        elm.classList.add(styles.controls);
    }

    static navigation(elm) {
        elm.classList.add(styles.navigation);
    }

    static saveButton(elm) {
        elm.innerText = 'Save';
        elm.classList.add('btn');
    }

    static resetButton(elm) {
        elm.innerText = 'Reset';
        elm.classList.add('btn');
    }

    static table(elm) {
        elm.classList.add('sheet-table');
    }

    static tableContainer(elm) {
        elm.classList.add('sheet-table__container');
    }

    static dayContainer(elm) {
        elm.classList.add('day-container');
    }

    static gameBox(elm) {
        elm.classList.add('element-box');
    }

    static gameBoxContainer(elm) {
        elm.classList.add('element-box__container');
    }

    static dayNumber(elm) {
        elm.classList.add('day-number');
    }

}


class TableUi {
    constructor(site) {
        this.site = site;
        this.number = site.number;
        this.elm = document.createElement('div');
        this.table = document.createElement('table');

        this.thead = document.createElement('thead');
        this.tbody = document.createElement('tbody');
        this.init();
    }

    init() {
        this.elm.id = 'tableContainer';
        Styler.tableContainer(this.elm);
        Styler.table(this.table);

        this.elm.appendChild(this.table);
        this.table.appendChild(this.thead);
        this.table.appendChild(this.tbody);

        this.createHeader();
        this.createBody();
    }

    createHeader() {
        const headerRow = document.createElement('tr');
        const headerCell = document.createElement('th');
        headerCell.innerText = 'Time';
        headerRow.appendChild(headerCell);
        this.site.areas.forEach(area => {
            const cell = document.createElement('th');
            cell.innerText = area;
            headerRow.appendChild(cell);
        });
        const th = document.createElement('th');
        this.thead.appendChild(headerRow);
    }

    createBody() {
        this.site.slots.forEach((slot, rowIndex) => {
            const row = document.createElement('tr');
            const timeCell = document.createElement('th');
            timeCell.innerText = slot;
            row.appendChild(timeCell);
            this.site.areas.forEach((area, colIndex) => {
                const cell = document.createElement('td');
                cell.innerText = '';
                cell.dataset.sheet = this.number;
                cell.dataset.row = rowIndex;
                cell.dataset.col = colIndex;
                row.appendChild(cell);
            });
            this.tbody.appendChild(row);
        });
    }
}



class ScheduleBuilder {
    title = 'Scheduler';
    id = 'scheduleBuilder';
    constructor(kernel) {
        this.kernel = kernel;
        this.elm = document.createElement('div');
        this.elm.id = this.id;

        this.gameBox = document.createElement('div')
        this.gameBox.id = 'gameContainer';

        this.prevDay = document.createElement('img');
        this.dayNumber = document.createElement('h2');
        this.nextDay = document.createElement('img');

        this.data = [];
        this.init();
        kernel.registerPage(this);
        this.registerKernelEvents();
    }

    init() {

        this.dayNumber.innerText = 'Day 1';

        const dayContainer = document.createElement('div');
        const gameBoxContainer = document.createElement('div');

        Styler.gameBox(this.gameBox);
        Styler.gameBoxContainer(gameBoxContainer);
        Styler.dayContainer(dayContainer)
        Styler.backButton(this.prevDay);
        Styler.dayNumber(this.dayNumber);
        Styler.forwardButton(this.nextDay);

        dayContainer.appendChild(this.prevDay);
        dayContainer.appendChild(this.dayNumber);
        dayContainer.appendChild(this.nextDay);
        gameBoxContainer.appendChild(this.gameBox);

        this.elm.appendChild(dayContainer);
        this.elm.appendChild(gameBoxContainer);
    }

    changeSite(number) {
        const table = this.data[0];
        if (!table) {
            throw new Error(`Site not found in ScheduleBuilder: ${number}`);
            return;
        }
        const tableContainer = document.getElementById('tableContainer');
        if (tableContainer) {
            tableContainer.remove();
        }
        this.elm.appendChild(table.elm);
    }

    addSite(site) {
        this.data.push(new TableUi(site));
    }

    registerKernelEvents() {
        this.kernel.on('siteChange', (number) => this.changeSite(number));
        this.kernel.on('siteAdd', (site) => this.addSite(site));
    }

}


class BracketNode {
    constructor(game) {
        this.game = game;
        this.next = game.children[0] || null;
        this.selected = false;
        this.is_related = false;
        this.is_parent = false;
        this.is_child = false;
        this.pending = game.pending;
        this.completed = game.completed;
        this.x = 0;
        this.y = 0;
    }
    contains(x, y) {
        return x > this.x - 50 && x < this.x + 50
            && y > this.y - 50 && y < this.y + 50;
    }

    getColorForNode() {
        if (this.selected) {
            return 'rgb(0, 100, 0)';
        } else if (this.is_related) {
            return 'rgb(100, 65, 0)';
        } else if (this.is_parent) {
            return 'rgb(0, 0, 100)';
        } else if (this.is_child) {
            return 'rgb(100, 0, 0)';
        } else if (this.pending) {
            return 'rgb(100, 100, 0)';
        } else if (this.completed) {
            return 'rgb(0, 100, 100)';
        }
        return 'rgb(90, 90, 90)';
    }
}



class CanvasUi {
    gameBoxHeight = 100;
    margin = 20;
    rowGap = 80;
    nodeHeight = 30;
    nodeWidth = 100;

    constructor() {
        this.elm = document.createElement('canvas');
        this.ctx = this.elm.getContext('2d');
        this.nodeMap = new Map();
        this.teams = [];
        this.init();
        this.elm.addEventListener('click', (e) => this.handleClick(e));
    }

    init() {
        this.elm.width = document.body.clientWidth - this.margin;
        this.elm.height = 600;
        this.elm.id = 'bracketCanvas';
        this.drawGameBox();
    }

    drawGameBox() {
        this.ctx.fillStyle = 'rgb(30, 30, 30)';
        this.ctx.fillRect(
            this.margin, this.margin, this.elm.width - this.margin, this.gameBoxHeight
        );
    }

    handleClick(e) {
        const rect = this.elm.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const node = this.findNode(x, y);
        node.selected = !node.selected;
        console.log(node);
        this.drawNode(node);
    }

    findNode(x, y) {
        return Array.from(this.nodeMap.values()).find(node => {
            return x > node.x - this.nodeWidth / 2 && x < node.x + this.nodeWidth / 2
                && y > node.y - this.nodeHeight / 2 && y < node.y + this.nodeHeight / 2;
        });
    }

    updateTeams(teams) {
        this.teams = teams;
    }

    calculatePositionFromParents(node) {
        if (!node.game.parents) {
            return;
        }
        if (node.game.parents.length === 0) {
            return;
        }
        if (node.game.parents.length === 1) {
            const parent = this.nodeMap.get(node.game.parents[0]);
            node.x = parent.x;
            node.y = parent.y + this.rowGap;
            return;
        }
        const parent1 = this.nodeMap.get(node.game.parents[node.game.parents.length -1]);
        const parent2 = this.nodeMap.get(node.game.parents[node.game.parents.length -2]);
        node.x = (parent1.x + parent2.x) / 2;
        node.y = parent1.y + this.rowGap;
    }

    render(nodes) {
        this.ctx.clearRect(0, 0, this.elm.width, this.elm.height);
        this.drawGameBox();
        let x = this.nodeWidth / 2 + this.margin;
        let y = this.gameBoxHeight + this.margin * 2;
        this.nodeMap = new Map();
        nodes.forEach(node => {
            this.nodeMap.set(node.game.number, node);
            node.x = x;
            node.y = y;
            this.calculatePositionFromParents(node);
            x += this.nodeWidth + this.margin;
        });
        nodes.forEach(node => {
            this.connectParents(node);
            this.drawNode(node);
        });
    }

    connectParents(node) {
        if (!node.game.parents) {
            return;
        }
        if (node.game.parents.length === 0) {
            return;
        }
        if (node.game.parents.length === 1) {
            const parent = this.nodeMap.get(node.game.parents[0]);
            this.connectNodes(parent, node);
            return;
        }
        const parent1 = this.nodeMap.get(node.game.parents[node.game.parents.length -1]);
        const parent2 = this.nodeMap.get(node.game.parents[node.game.parents.length -2]);
        this.connectNodes(parent1, node);
        this.connectNodes(parent2, node);
    }

    nodeTextContent(node) {
        let teamRed = this.teams.find(team => team.number === node.game.teamRed);
        let teamBlue = this.teams.find(team => team.number === node.game.teamBlue);
        if (!teamRed) { teamRed = 'Unknown'; }
        if (!teamBlue) { teamBlue = 'Unknown'; }

        return `Game ${node.game.number}`;
    }


    drawNode(node) {
        const color = node.getColorForNode();
        const rectX = node.x - this.nodeWidth / 2; 
        const rectY = node.y - this.nodeHeight / 2;
        const rectWidth = this.nodeWidth;
        const rectHeight = this.nodeHeight;
        const radius = 5;

        this.ctx.beginPath();
        this.ctx.moveTo(rectX + radius, rectY);
        this.ctx.arcTo(rectX + rectWidth, rectY, rectX + rectWidth, rectY + rectHeight, radius);
        this.ctx.arcTo(rectX + rectWidth, rectY + rectHeight, rectX, rectY + rectHeight, radius);  // Bottom-right corner
        this.ctx.arcTo(rectX, rectY + rectHeight, rectX, rectY, radius);
        this.ctx.arcTo(rectX, rectY, rectX + rectWidth, rectY, radius);
        this.ctx.closePath();

        this.ctx.fillStyle = color;
        this.ctx.fill();

        this.ctx.strokeStyle = 'rgb(255, 255, 255)';
        this.ctx.lineWidth = 2;
        this.ctx.stroke();

        this.ctx.fillStyle = 'rgb(255, 255, 255)';
        this.ctx.font = '16px Roboto';
        this.ctx.textAlign = 'center';
        this.ctx.textBaseline = 'middle';
        this.ctx.fillText(this.nodeTextContent(node), node.x, node.y);
    }

    connectNodes(node1, node2) {
        this.ctx.beginPath();
        this.ctx.moveTo(node1.x, node1.y + this.nodeHeight / 2);
        this.ctx.lineTo(node2.x, node2.y - this.nodeHeight / 2);
        this.ctx.stroke();
        this.ctx.closePath();
    }
}

class BracketBuilder {
    title = 'BracketBuilder';


    constructor(kernel) {
        this.kernel = kernel;
        this.elm = document.createElement('div');
        this.elm.id = 'bracketBuilder';
        kernel.registerPage(this);
        this.registerKernelEvents();
        this.canvas = new CanvasUi();
        this.elm.appendChild(this.canvas.elm);
        this.data = [];
    }

    setNodesStatus(nodes, related) {
        nodes.forEach(node => {
            if (related.assigned.parents.includes(node.game)) {
                node.is_parent = true;
            }
            if (related.assigned.children.includes(node.game)) {
                node.is_child = true;
            }
            if (related.selected === node.game) {
                node.selected = true;
            }
            if (related.unassigned.parents.includes(node.game) || related.unassigned.children.includes(node.game)) {
                node.is_related = true;
            }
        });
    }


    contextMenu(e) {
    }

    changeDivision(number) {
        const division = this.kernel.state.divisions.get(number);
        const related = division.getRelatedGames();
        const nodes = related.members.map(game => new BracketNode(game));
        this.canvas.updateTeams(division.teams);
        this.setNodesStatus(nodes, related);
        this.canvas.render(nodes);
        this.data = nodes;
    }

    selectGame(divisionNumber, gameNumber) {
        const division = this.kernel.state.divisions.get(divisionNumber);
        const related = division.getRelatedGames();
        const nodes = this.data;
    }

    registerKernelEvents() {
        this.kernel.on('divisionChange', (number) => this.changeDivision(number));
        this.kernel.on('gameSelect', (divisionNumber, gameNumber) => this.selectGame(divisionNumber, gameNumber));
    }
}




class MatchBuilder {
    title = 'MatchBuilder';
    id = 'matchBuilder';
    constructor(kernel) {
        this.kernel = kernel;
        this.elm = document.createElement('div');
        this.elm.id = this.id;
        this.init();
        kernel.registerPage(this);
    }

    init() {
        this.elm.innerText = this.title;
    }

    changeSite(number) {
        this.elm.innerText = `${this.title} - Site ${number}`;
    }
}

class Controls {
    id = {
        pageTitle: 'pageTitle',
        backButton: 'backButton',
        forwardButton: 'forwardButton',
        siteSelect: 'siteSelect',
        divisionSelect: 'divisionSelect',
        bracketTypeSelect: 'bracketTypeSelect',
        saveButton: 'saveButton',
        resetButton: 'resetButton',
    };

    constructor(kernel) {
        this.elm = document.createElement('div');
        this.nav = document.createElement('div');
        this.title = document.createElement('h1');
        this.backButton = document.createElement('img');
        this.forwardButton = document.createElement('img');
        this.selections = document.createElement('div');
        this.siteSelect = document.createElement('select');
        this.divisionSelect = document.createElement('select');
        this.bracketTypeSelect = document.createElement('select');
        this.saveButton = document.createElement('button');
        this.resetButton = document.createElement('button');

        this.closeButton = document.createElement('img');
        this.init();
    }

    init() {
        this.saveButton.innerText = 'Save';
        this.resetButton.innerText = 'Reset';

        Styler.controls(this.elm);
        Styler.navigation(this.nav);
        Styler.title(this.title);
        Styler.backButton(this.backButton);
        Styler.forwardButton(this.forwardButton);
        Styler.selections(this.selections);
        Styler.saveButton(this.saveButton);
        Styler.resetButton(this.resetButton);
        Styler.closeButton(this.closeButton);

        this.nav.appendChild(this.backButton);
        this.nav.appendChild(this.title);
        this.nav.appendChild(this.forwardButton);
        this.elm.appendChild(this.nav);

        this.selections.appendChild(this.siteSelect);
        this.selections.appendChild(this.divisionSelect);
        this.selections.appendChild(this.bracketTypeSelect);
        this.selections.appendChild(this.saveButton);
        this.selections.appendChild(this.resetButton);
        this.elm.appendChild(this.selections);

        this.elm.appendChild(this.closeButton);
    }
}

class Overlay {
    id = 'overlay';
    constructor(kernel) {
        this.kernel = kernel;

        this.elm = document.createElement('div');
        this.elm.id = this.id;

        this.controls = new Controls();
        this.pageContainer = document.createElement('div');
        this.openButton = document.getElementById('bracketOpenButton')

        this.addEventListeners();
        this.registerKernelEvents();
    }

    setContent(page) {
        this.pageContainer.innerHTML = '';
        this.pageContainer.appendChild(page.elm);
    }

    changeTitle(page) {
        this.controls.title.innerText = page.title;
    }

    open() {
        this.elm.classList.add('show');
    }

    close() {
        this.elm.classList.remove('show');
    }

    addSiteOptions(site) {
        const option = document.createElement('option');
        option.value = site.number;
        option.innerText = site.name;
        this.controls.siteSelect.appendChild(option);
    }

    addDivisionOptions(division) {
        const option = document.createElement('option');
        option.value = division.number;
        option.innerText = division.name;
        this.controls.divisionSelect.appendChild(option);
    }

    changeSite(number) {
        this.controls.siteSelect.value = number;
    }

    changeDivision(number) {
        this.controls.divisionSelect.value = number;
    }

    changeBracketType(type) {
        this.controls.bracketTypeSelect.value = type;
    }

    attach() {
        Styler.overlay(this.elm);
        Styler.openButton(this.openButton);

        this.elm.appendChild(this.controls.elm);
        this.elm.appendChild(this.pageContainer);

        document.body.appendChild(this.elm);
    }

    addEventListeners() {
        this.openButton.addEventListener('click', () => this.open());
        this.controls.closeButton.addEventListener('click', () => this.close());
        this.controls.backButton.addEventListener('click', () => this.kernel.prevPage());
        this.controls.forwardButton.addEventListener('click', () => this.kernel.nextPage());
        this.controls.siteSelect.addEventListener('change', (e) => this.kernel.changeSite(Number(e.target.value)));
        this.controls.divisionSelect.addEventListener('change', (e) => this.kernel.changeDivision(Number(e.target.value)));
        this.controls.bracketTypeSelect.addEventListener('change', (e) => this.kernel.changeBracketType(Number(e.target.value)));
        this.controls.saveButton.addEventListener('click', () => this.kernel.save());
        this.controls.resetButton.addEventListener('click', () => this.kernel.reset());
    }

    registerKernelEvents() {
        this.kernel.on('pageChange', (page) => {
            console.log('Changing page');
            this.setContent(page);
            this.changeTitle(page);
        });
        this.kernel.on('siteChange', (number) => this.changeSite(number));
        this.kernel.on('siteAdd', (site) => this.addSiteOptions(site));
        this.kernel.on('divisionAdd', (division) => this.addDivisionOptions(division));
        this.kernel.on('divisionChange', (number) => this.changeDivision(number));
    }
}

class Pages {
    constructor() {
        this.pages = [];
        this.activePage = 0;
    }

    addPage(page) {
        this.pages.push(page);
    }

    getPage() {
        return this.pages[this.activePage];
    }

    nextPage() {
        this.activePage++;
        if (this.activePage >= this.pages.length) {
            this.activePage = 0;
        }
    }

    prevPage() {
        this.activePage--;
        if (this.activePage < 0) {
            this.activePage = this.pages.length - 1;
        }
    }

}

class EventEmitter {
    constructor() {
        this.events = {};
    }

    on(event, callback) {
        if (!this.events[event]) {
            this.events[event] = [];
        }
        this.events[event].push(callback);
    }

    off(event, callback) {
        if (!this.events[event]) return;
        const index = this.events[event].indexOf(callback);
        if (index !== -1) {
            this.events[event].splice(index, 1);
        }
    }

    emit(event, ...args) {
        if (this.events[event]) {
            this.events[event].forEach((callback) => callback(...args));
        }
    }
}

class Kernel extends EventEmitter {
    constructor() {
        super();
        this.state = new State();
        this.pages = new Pages();
        this.overlay = new Overlay(this);
        this.overlay.attach();
    }

    loadState(stateData) {
        this.state.loadData(stateData);

        // add sites, divisions, games
        this.state.sites.sheets
            .forEach(site => this.emit('siteAdd', site));

        this.state.divisions.data
            .forEach(division => this.emit('divisionAdd', division));

        this.state.divisions.data
            .forEach(division => division.games
                .forEach(game => this.emit('gameAdd', game)));
    }

    registerPage(page) {
        this.pages.addPage(page);
    }

    nextPage() {
        this.pages.nextPage();
        this.emit('pageChange', this.pages.getPage());
    }

    prevPage() {
        this.pages.prevPage();
        this.emit('pageChange', this.pages.getPage());
    }

    changeSite(number) {
        this.state.setSite(number);
        this.emit('siteChange', number);
    }

    changeDivision(number) {
        this.state.setDivision(number);
        this.emit('divisionChange', number);
    }

    changeBracketType(type) {
        this.emit('bracketTypeChange', type);
    }

    selectGame(divisionNumber, gameNumber) {
        this.emit('gameSelect', divisionNumber, gameNumber);
    }

    selectCell(sheetIndex, rowIndex, columnIndex) {
        this.emit('cellSelect', sheetIndex, rowIndex, columnIndex);
    }

    clearGame(game) {
        this.emit('gameClear', game);
    }

    clearCell(sheetIndex, rowIndex, columnIndex) {
        this.emit('cellClear', sheetIndex, rowIndex, columnIndex);
    }

    save() {
        console.warn('Save not implemented');
        this.emit('save');
    }

    saveDraft() {
        console.warn('Save Draft not implemented');
        this.emit('saveDraft');
    }

    reset() {
        console.warn('Reset not implemented');
        this.emit('reset');
    }

    setGame(sheetIndex, rowIndex, columnIndex, game) {
        this.emit('gameSet', sheetIndex, rowIndex, columnIndex, game);
    }

}

document.addEventListener('DOMContentLoaded', () => {
    const kernel = new Kernel();
    new ScheduleBuilder(kernel);
    new BracketBuilder(kernel);
    new MatchBuilder(kernel);
    kernel.loadState(loadState());
    kernel.emit('pageChange', kernel.pages.getPage());
    console.log(kernel.state);
});
