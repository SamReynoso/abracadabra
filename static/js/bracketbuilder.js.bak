function loadState() {
    const localDraft = localStorage.getItem('kernelState');
    if (localDraft) {
        console.log('Loading draft from local storage');
        try {
            JSON.parse(localDraft);
        } catch (e) {
            console.error(e);
            localStorage.removeItem('kernelState');
        }
    }
    const draft = Ajax.fetchDraft();
    if (draft) {
        console.log('Loading draft from server');
        localStorage.setItem('kernelState', JSON.stringify(draft));
        return draft;
    }
    const savedState = Ajax.fetchState();
    localStorage.setItem('kernelState', JSON.stringify(savedState));
    console.log('Loading saved state');
    return savedState;
}

class Division  {
    constructor(data) {
        this.id = data.id;
        this.number = data.number;
        this.name = data.name;
        this.bracketType = data.bracketType;
        this.loserBracket = data.loserBracket;
        this.selectedGame = data.selectedGame;
        this.teams = data.teams.map(team => new Team(team));
        this.games = data.games.map(game => new Game(game));
    }

    getData() {
        return {
            id: this.id,
            number: this.number,
            name: this.name,
            bracketType: this.bracketType,
            loserBracket: this.loserBracket,
            selectedGame: this.selectedGame,
            teams: this.teams.map(team => team.getData()),
            games: this.games.map(game => game.getData()),
        }
    }

    getRelatedGames() {
        const selected = this.games.find(game => game.number === this.selectedGame);
        const assigned = this.games.filter(game => game.is_assigned());
        const unassigned = this.games.filter(game => !game.is_assigned());

        return {
            selected: selected,
            members: this.games,
            assigned: {
                parents: assigned.filter(game => selected.parents.includes(game.number)), 
                children: assigned.filter(game => selected.children.includes(game.number)),
            },
            unassigned: {
                parents: unassigned.filter(game => selected.parents.includes(game.number)), 
                children: unassigned.filter(game => selected.children.includes(game.number)),
            }
        }
    }
}


class Team {
    constructor(data) {
        this.id = data.id;
        this.number = data.number;
        this.name = data.name;
    }

    getData() {
        return {
            id: this.id,
            number: this.number,
            name: this.name,
        }
    }
}


class Game {
    constructor(data) {
        this.id = data.id;
        this.number = data.number;
        this.division = data.division;
        this.teamRed = data.teamRed;
        this.teamBlue = data.teamBlue;
        this.parents = data.parents;
        this.children = data.children;
        this.pending = data.pending;
        this.completed = data.completed;
        this.winner = data.winner;
        this.site = data.site;
        this.day = data.day;
        this.area = data.area;
        this.slot = data.slot;
    }

    is_assigned() {
        return this.site !== null
    }

    getData() {
        return {
            id: this.id,
            number: this.number,
            division: this.division,
            teamRed: this.teamRed,
            teamBlue: this.teamBlue,
            parents: this.parents,
            children: this.children,
            pending: this.pending,
            completed: this.completed,
            winner: this.winner,
            site: this.site,
            area: this.area,
            slot: this.slot,
        }
    }
}

class Sheet {
    constructor(site) {
        this.id = site.id;
        this.name = site.name;
        this.number = site.number;
        this.start = site.start;
        this.end = site.end;
        this.areas = site.areas;
        this.slots = site.slots;
        const height = site.slots.length;
        const width = site.areas.length;
        this.grid = Array.from({ length: height }, () => Array.from({ length: width }, () => null));
    }

    changeAreaLabel(labelPrefix) {
        for (let i = 0; i < this.areas.length; i++) {
            this.areas[i] = `${labelPrefix} ${i + 1}`;
        }
    }

    changeSlotStart(time) {
        this.start = time;
    }

    changeSlotEnd(time) {
        this.end = time;
    }

    changeSlotDuration(duration) {
        let time = this.start;
        this.slots = [];
        while (time < this.end) {
            let hours = Math.floor(time / 60);
            let minutes = time % 60;
            let suffix = hours < 12 ? 'AM' : 'PM';
            hours = hours % 12;
            if (hours === 0) hours = 12;
            this.slots.push(`${hours}:${minutes} ${suffix}`);
            time += duration;

        }
    }

    getData() {
        return {
            id: this.id,
            name: this.name,
            number: this.number,
            start: this.start,
            end: this.end,
            areas: this.areas,
            slots: this.slots,
        }
    }

}

class SitesManager {
    loadData(data) {
        this.sheets = data.sites.map(site => new Sheet(site));
    }

    setGame(sheetIndex, rowIndex, columnIndex, game) {
        this.sheets[sheetIndex].grid[rowIndex][columnIndex] = game;
        game.site = sheetIndex;
        game.area = rowIndex;
        game.slot = columnIndex;
    }

    getGame(sheetIndex, rowIndex, columnIndex) {
        return this.sheets[sheetIndex].grid[rowIndex][columnIndex];
    }

    clearCell(sheetIndex, rowIndex, columnIndex) {
        const game = this.getGame(sheetIndex, rowIndex, columnIndex);
        this.sheets[sheetIndex].grid[rowIndex][columnIndex] = null;
        game.site = null;
        game.area = null;
        game.slot = null;
    }

    clearGame(game) {
        this.sheets[game.site].grid[game.area][game.slot] = null;
        game.site = null;
        game.area = null;
        game.slot = null;
    }
}

class DivisionManager {
    constructor() {
        this.data = [];
    }

    get(number) {
        return this.data.find(division => division.number === number);
    }

    loadData(data) {
        this.data = data.divisions.map(division => new Division(division));
    }

    getData() {
        return this.data.map(division => division.getData());
    }
}

class State {
    constructor() {
        this.metaData = {};
        this.sites = new SitesManager();
        this.divisions = new DivisionManager();
    }

    setCurrentPage(index) {
        this.metaData.currentPage = index;
    }

    setDay(number) {
        this.metaData.selectedDay = number;
    }

    setSite(number) {
        this.metaData.selectedSite = number;
    }

    setDivision(number) {
        this.metaData.selectedDivision = number;
    }

    setAreaLabel(label) {
        this.metaData.areaLabel = label;
    }

    setSiteLabel(label) {
        this.metaData.siteLabel = label;
    }

    loadData(data) {
        this.metaData = data.meta;
        this.sites.loadData(data);
        this.divisions.loadData(data);
    }

    serialize() {
        const data = {
            meta: this.metaData.getData(),
            sites: this.sites.getData(),
            divisions: this.divisions.getData(),
        }
        return JSON.stringify(data);
    }

}
